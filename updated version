<script>
  const state = { exp: 0, proj: 0 };

  function moveSlide(type, direction) {
    const carousel = document.querySelector(`#${type}Carousel .carousel-track`);
    const cards = carousel.children;
    state[type] += direction;
    if (state[type] < 0) state[type] = cards.length - 1;
    if (state[type] >= cards.length) state[type] = 0;
    carousel.style.transform = `translateX(-${state[type] * 100}%)`;
    Array.from(cards).forEach((card, i) => {
      card.classList.toggle('active', i === state[type]);
    });
  }
</script>

